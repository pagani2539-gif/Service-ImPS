DB_HOST=localhost
DB_USER=imps
DB_PASSWORD=1234
DB_NAME=imps_db
WS_SERVER_URL=ws://localhost:4000/vehicle/receive
IMAGE_LPR_UPLOAD_URL=http://localhost:3003/api/upload/lpr
IMAGE_CROP_UPLOAD_URL=http://localhost:3003/api/upload/crop
IMAGE_OVERVIEW_UPLOAD_URL=http://localhost:3003/api/upload/overview
VMS_URL=http://localhost:3006/api/vms
TRANSMISSION_URL=http://localhost:3007/api/vehicles/data-transmission
THREE_DIMENSION_BASE=http://10.1.28.20:3210 #ถ้าไม่มี 3D ให้ลบค่าหลัง = ออก
THREE_DIMENSION_DELAY=5000
THREE_DIMENSION_MAXIMUM_HEIGHT=3500
PICO_BASE=http://192.168.145.110:8000 #ถ้าไม่มี pico ให้ลบค่าหลัง = ออก
# ==========================================
# การจับคู่รูปภาพรถ และ Performance Metrics
# ==========================================

# 1. การจับคู่รูปภาพ Snap กับข้อมูลรถ (หน่วย: ms)
# - SNAP_MATCH_DB_POLL_MS  = ความถี่ในการเช็คข้อมูลในฐานข้อมูลระหว่างรอรูป (ระบบมี event-driven เช็คใน memory ด้วย)
# - SNAP_MATCH_MAX_WAIT_MS = เวลารอรูปภาพสูงสุด (หากระบบจับคู่รูปไม่ทัน ให้ปรับค่านี้เพิ่มขึ้น)
SNAP_MATCH_DB_POLL_MS=1000
SNAP_MATCH_MAX_WAIT_MS=3000

# 2. ภาพขึ้นช้า / ต้องกด F5 (HEAD readiness check)
# ระบบจะเช็คว่าไฟล์รูป serve ได้จริงก่อนแจ้ง browser (กันภาพ 404 ต้องกด F5) — ปกติไม่ต้องตั้ง
# - TRANSMIT_READY_CAP_MS  = เพดานรอไฟล์สูงสุด (ms) กันค้างถ้า image server ล่ม (default 1500)
# - TRANSMIT_READY_POLL_MS = ความถี่เช็คไฟล์ (ms) ถ้ารถหนาแน่นมากปรับให้ห่างขึ้นลดโหลด image server (default 50)
#TRANSMIT_READY_CAP_MS=1500
#TRANSMIT_READY_POLL_MS=50

# 2b. เวลา retry หารูปที่ขาด (ลด latency ตอนรูปมาช้า/ขาด)
# - IMAGE_RETRY_COUNT    = จำนวนรอบ retry หารูป (default 3; เดิม 5)
# - IMAGE_RETRY_DELAY_MS = ช่องว่างระหว่างรอบ (ms) คงที่ (default 500; findSnapshots รอ event-driven ~3s/รอบให้อยู่แล้ว)
#IMAGE_RETRY_COUNT=3
#IMAGE_RETRY_DELAY_MS=500

# 3. Performance Metrics
# - METRICS_INTERVAL_MS = ช่วงเวลารอบการสรุป Log ประสิทธิภาพ (เช่น 300000 ms = 5 นาที)
# - METRICS_FORMAT      = รูปแบบแสดงผล: pretty (หลายบรรทัด อ่านง่าย) / compact (บรรทัดเดียว)
METRICS_INTERVAL_MS=300000
METRICS_FORMAT=pretty

# 4. กำหนดช่วงเวลาค้นหาจับคู่รูปภาพย้อนหลัง/ล่วงหน้า (หน่วย: ms)
# - ลบ # ด้านหน้าออก เพื่อเปิดใช้งาน (Override ค่าใน DB ชั่วคราวโดยไม่ต้องแก้ DB)
# - SNAP_MATCH_BACK_MS = ช่วงเวลาจับคู่ย้อนหลัง
#   → ถ้าตั้งกล้อง LPR ให้ถ่ายก่อนถึง Sensor เช่น 2 วิ ให้ตั้งเป็น 4000 (2000 + buffer 2000)
# - SNAP_MATCH_FWD_MS  = ช่วงเวลาจับคู่ล่วงหน้า (ถ้าเจอรูปสลับคัน/ถ่ายท้ายรถ ให้ลองลดค่านี้ลง)
#SNAP_MATCH_BACK_MS=4000
#SNAP_MATCH_FWD_MS=8000

# 4. ปรับแต่งภาพก่อนส่งเข้า OCR (sharpen/denoise/normalise) เพื่อช่วยอ่านป้ายที่เล็ก/มืด/เบลอ
# - OCR_PREPROCESS=1 เปิด, =0 หรือไม่ใส่ = ปิด (ค่าเริ่มต้นปิด)
# - แนะนำเก็บ baseline (=0) เทียบกับ (=1) ก่อน ว่าอ่านป้ายดีขึ้นจริงไหม ถ้าแย่ลงให้ปิดกลับ
# - ไม่ resize/crop ภาพ (คงพิกัด crop ป้ายให้ตรง) ปรับแค่ค่าพิกเซลของภาพที่ป้อน OCR เท่านั้น
#OCR_PREPROCESS=1
