DB_HOST=localhost
DB_USER=imps
DB_PASSWORD=1234
DB_NAME=imps_db
WS_SERVER_URL=ws://localhost:4000/vehicle/receive
IMAGE_LPR_UPLOAD_URL=http://localhost:3003/api/upload/lpr
IMAGE_CROP_UPLOAD_URL=http://localhost:3003/api/upload/crop
IMAGE_OVERVIEW_UPLOAD_URL=http://localhost:3003/api/upload/overview
VMS_URL=http://localhost:3006/api/vms
TRANSMISSION_URL=http://localhost:3007/api/vehicles/data-transmission
THREE_DIMENSION_BASE=http://10.1.28.20:3210 #ถ้าไม่มี 3D ให้ลบค่าหลัง = ออก
THREE_DIMENSION_DELAY=5000
THREE_DIMENSION_MAXIMUM_HEIGHT=3500
PICO_BASE=http://192.168.145.110:8000 #ถ้าไม่มี pico ให้ลบค่าหลัง = ออก
# รอจับคู่ snap กับรถ (ms) — เพิ่ม SNAP_MATCH_MAX_WAIT_MS ถ้ายังไม่เจอรูป
# SNAP_MATCH_DB_POLL_MS = ความถี่ขั้นต่ำของการเช็ค DB ระหว่างรอ (memory เช็คแบบ event-driven อยู่แล้ว)
SNAP_MATCH_DB_POLL_MS=1000
SNAP_MATCH_MAX_WAIT_MS=3000
# รอบสรุป [Metrics] ลง log (ms) — นับรถ/drop, เวลาประมวลผล, CPU, memory, event-loop lag
METRICS_INTERVAL_MS=300000
# จับคู่รูป↔รถ: override ช่วงเวลา (ms) ทับค่าใน DB (minimum_search/maximum_search) โดยไม่ต้องแก้ DB
# ลด SNAP_MATCH_FWD_MS ถ้าเจอ "ภาพคนละคัน/ถ่ายท้ายรถ" — ดู snap_offset_*_ms ใน [Metrics] แล้วตั้งให้พอครอบ p95
#SNAP_MATCH_BACK_MS=2000
#SNAP_MATCH_FWD_MS=8000
# หน้าต่างมองย้อนประวัติ trigger (ms) ก่อนตัดสินใจถ่ายสดสำรอง — โค้ดเดิม 3000, design เดิม 15000
#TRIGGER_HISTORY_WINDOW_MS=3000