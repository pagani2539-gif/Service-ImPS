DB_HOST=localhost
DB_USER=imps
DB_PASSWORD=1234
DB_NAME=imps_db
WS_SERVER_URL=ws://localhost:4000/vehicle/receive
IMAGE_LPR_UPLOAD_URL=http://localhost:3003/api/upload/lpr
IMAGE_CROP_UPLOAD_URL=http://localhost:3003/api/upload/crop
IMAGE_OVERVIEW_UPLOAD_URL=http://localhost:3003/api/upload/overview
VMS_URL=http://localhost:3006/api/vms
TRANSMISSION_URL=http://localhost:3007/api/vehicles/data-transmission
THREE_DIMENSION_BASE=http://10.1.28.20:3210 #ถ้าไม่มี 3D ให้ลบค่าหลัง = ออก
THREE_DIMENSION_DELAY=5000
THREE_DIMENSION_MAXIMUM_HEIGHT=3500
# ==========================================
# การจับคู่รูปภาพรถ และ Performance Metrics
# ==========================================

# 1. การจับคู่รูปภาพ Snap กับข้อมูลรถ (หน่วย: ms)
# - SNAP_MATCH_DB_POLL_MS  = ความถี่ในการเช็คข้อมูลในฐานข้อมูลระหว่างรอรูป (ระบบมี event-driven เช็คใน memory ด้วย)
# - SNAP_MATCH_MAX_WAIT_MS = เวลารอรูปภาพสูงสุด (หากระบบจับคู่รูปไม่ทัน ให้ปรับค่านี้เพิ่มขึ้น)
SNAP_MATCH_DB_POLL_MS=1000
SNAP_MATCH_MAX_WAIT_MS=3000

# 2. ภาพขึ้นช้า / ต้องกด F5 (HEAD readiness check)
# ระบบจะเช็คว่าไฟล์รูป serve ได้จริงก่อนแจ้ง browser (กันภาพ 404 ต้องกด F5) — ปกติไม่ต้องตั้ง
# - TRANSMIT_READY_CAP_MS  = เพดานรอไฟล์สูงสุด (ms) กันค้างถ้า image server ล่ม (default 1500)
# - TRANSMIT_READY_POLL_MS = ความถี่เช็คไฟล์ (ms) ถ้ารถหนาแน่นมากปรับให้ห่างขึ้นลดโหลด image server (default 50)
# - IMAGE_SERVE_BASE_URL   = base ของ image server สำหรับเช็ค servable เมื่อ image server คืน fileUrl แบบ relative
#                            ปกติไม่ต้องตั้ง (ระบบใช้ origin ของ IMAGE_*_UPLOAD_URL ให้เอง เช่น http://localhost:3003)
#                            ตั้งเฉพาะกรณี host ที่ serve รูป ต่างจาก host ที่ upload
#TRANSMIT_READY_CAP_MS=1500
#TRANSMIT_READY_POLL_MS=50
#IMAGE_SERVE_BASE_URL=http://localhost:3003

# 2b. เวลา retry หารูปที่ขาด (ลด latency ตอนรูปมาช้า/ขาด)
# - IMAGE_RETRY_COUNT    = จำนวนรอบ retry หารูป (default 3; เดิม 5)
# - IMAGE_RETRY_DELAY_MS = ช่องว่างระหว่างรอบ (ms) คงที่ (default 500; findSnapshots รอ event-driven ~3s/รอบให้อยู่แล้ว)
#IMAGE_RETRY_COUNT=3
#IMAGE_RETRY_DELAY_MS=500

# 3. Performance Metrics
# - METRICS_INTERVAL_MS = ช่วงเวลารอบการสรุป Log ประสิทธิภาพ (เช่น 300000 ms = 5 นาที)
# - METRICS_FORMAT      = รูปแบบแสดงผล: pretty (หลายบรรทัด อ่านง่าย) / compact (บรรทัดเดียว)
METRICS_INTERVAL_MS=300000
METRICS_FORMAT=pretty

# 4. กำหนดช่วงเวลาค้นหาจับคู่รูปภาพย้อนหลัง/ล่วงหน้า (หน่วย: ms)
# - ลบ # ด้านหน้าออก เพื่อเปิดใช้งาน (Override ค่าใน DB ชั่วคราวโดยไม่ต้องแก้ DB)
# - SNAP_MATCH_BACK_MS = ช่วงเวลาจับคู่ย้อนหลัง
#   → ถ้าตั้งกล้อง LPR ให้ถ่ายก่อนถึง Sensor เช่น 2 วิ ให้ตั้งเป็น 4000 (2000 + buffer 2000)
# - SNAP_MATCH_FWD_MS  = ช่วงเวลาจับคู่ล่วงหน้า (ถ้าเจอรูปสลับคัน/ถ่ายท้ายรถ ให้ลองลดค่านี้ลง)
#SNAP_MATCH_BACK_MS=4000
#SNAP_MATCH_FWD_MS=8000

# 4. ปรับแต่งภาพก่อนส่งเข้า OCR (sharpen/denoise/normalise) เพื่อช่วยอ่านป้ายที่เล็ก/มืด/เบลอ
# - OCR_PREPROCESS=1 เปิด, =0 หรือไม่ใส่ = ปิด (ค่าเริ่มต้นปิด)
# - แนะนำเก็บ baseline (=0) เทียบกับ (=1) ก่อน ว่าอ่านป้ายดีขึ้นจริงไหม ถ้าแย่ลงให้ปิดกลับ
# - ไม่ resize/crop ภาพ (คงพิกัด crop ป้ายให้ตรง) ปรับแค่ค่าพิกเซลของภาพที่ป้อน OCR เท่านั้น
#OCR_PREPROCESS=1

# 4.1 Two-pass OCR: รอบแรกอ่านภาพ raw ไม่ออก (no plate) → ลองซ้ำด้วยภาพ enhanced อัตโนมัติ
# - แก้เคส "อ่านไม่ออกเลย" เฉพาะคันที่รอบแรกพลาด (เคสที่อ่านออกอยู่แล้วไม่กระทบ/ไม่เสีย OCR เพิ่ม)
# - OCR_RETRY_ENHANCE=1 หรือไม่ใส่ = เปิด (ค่าเริ่มต้นเปิด), =0 = ปิด
# - ถ้า OCR_PREPROCESS=1 อยู่แล้ว รอบแรกก็เป็น enhanced → ข้าม retry ให้เอง (ไม่ยิงซ้ำเปลือง)
# - วัดผลได้จาก [Metrics]: ocr_no_plate (พลาดรอบแรก) / ocr_recovered_by_enhance (กู้กลับได้) / ocr_retry_ms (เวลาที่เพิ่ม)
#OCR_RETRY_ENHANCE=0

# 4.2 ถ่าย LPR หลายเฟรม/คัน (burst) — เฟรมแรกอ่านไม่ออก → เลือกเฟรมที่อ่านออก/คมสุด (เฉพาะกล้อง LPR; overview ใบเดียว)
# - LPR_BURST_FRAMES = ถ่ายกี่เฟรม/คัน (default 2; =1 = ปิด burst กลับเป็นเฟรมเดียว)
# - LPR_BURST_GAP_MS = ระยะห่างระหว่างเฟรม (ms); 0 = ยิงติดกัน (ป้ายขยับน้อยสุด กันหลุดเฟรม) เพิ่มถ้ากล้องคืนเฟรมซ้ำ
# - OCR เฟรม 2 ทำเฉพาะตอนเฟรม 1 พลาด (รถปกติไม่ช้าลง); ต้นทุนคงที่ = ถ่ายเพิ่ม 1 รูป/คัน
# - วัดผล [Metrics]: lpr_burst_captured / plate_recovered_by_extra_frame (เฟรม2ช่วยกู้) / burst_frames_identical (เฟรมซ้ำ-เฝ้าระวัง)
#LPR_BURST_FRAMES=2
#LPR_BURST_GAP_MS=0

# 4.3 Watchdog เตือน trigger sensor เงียบ — มีรถเข้าแต่ไม่มี trigger = sensor ถ่ายภาพอาจพัง (ป้ายหายเงียบ ไม่มี error)
# - TRIGGER_SILENCE_MS  = ไม่มี trigger กี่ ms ถือว่าเงียบ (default 30000)
# - TRIGGER_WATCHDOG_MS = เช็คทุกกี่ ms (default 15000)
# - เตือนครั้งเดียวตอนเข้าสถานะเงียบ (log error [Trigger][Watchdog] + counter trigger_sensor_silent); กลับมา = log recovered
#TRIGGER_SILENCE_MS=30000
#TRIGGER_WATCHDOG_MS=15000

# 5. Diagnostic logging (เฟส 1: เก็บข้อมูลหา root cause ก่อนแก้)
# - DIAG=1 เปิด → log [Diag][...] 13 หมวด ลง info-*.log (ระบบทำงานปกติ ไม่เปลี่ยนพฤติกรรม)
#   ใช้คู่กับ: node scripts/analyze-diag.js logs/info-YYYY-MM-DD.log
# - ไม่ใส่/ลบออก = ปิด (ไม่มี log เสริม ไม่มี overhead) — เปิดเฉพาะช่วงเก็บข้อมูลแล้วปิดกลับ
# - LOG_MAX_SIZE override ขนาดไฟล์ก่อน rotate (default DIAG=1 → 100m, ปกติ 20m)
#DIAG=1
#LOG_MAX_SIZE=100m

# 6. จูนระบบจับคู่รถคร่อมเลน (straddling) — override ค่าใน DB ผ่าน .env ได้ ไม่ต้องแตะ DB
#    ไม่ใส่ = ใช้ค่าจาก DB (poll ทุก 5 วิ); ใส่ = override ทันที (restart)
# - STRADDLING_TIME_DIFF   = หน้าต่างถือ buffer รอคู่ (วินาที) — คู่จริงห่างกัน p95=11ms → ลด 3→1 ได้ปลอดภัย ลด false-merge
# - STRADDLE_MATCH_MS      = หน้าต่าง "suppress-dup" (±ms) — ทิ้ง record ครึ่งคันที่ซ้ำกับคู่ที่บันทึกแล้ว (destructive ต้องแคบ, default 50)
# - STRADDLE_CONFIRM_MS    = หน้าต่าง "confirm-straddle" (±ms) — ยืนยันคร่อมเลน+mirror กู้น้ำหนักประมาณ (non-destructive ขยายได้, default 250)
#                            *กันจับรถปกติผิดด้วย "ตัวกรองชนิดคู่" (ต้องมีสัญญาณคร่อมเลน) ไม่ใช่ความกว้างหน้าต่าง
# - STRADDLING_AXLE_TOL    = จำนวนเพลาที่ต่างกันได้ (default 3)
# - STRADDLING_SPEED_DIFF  = ความเร็วต่างกันได้ กม./ชม. (default 15)
# - STRADDLING_WHEELBASE_DIFF = ฐานล้อต่างกันได้ ซม. (default 30)
# - STRADDLING_ZERO_KG     = เกณฑ์ตัดสิน "ด้านศูนย์" ต่อล้อ กก. (default 100)
#STRADDLING_TIME_DIFF=1
#STRADDLE_MATCH_MS=50
#STRADDLE_CONFIRM_MS=250
# - STRADDLE_PARTNER_FLOOR  = น้ำหนักขั้นต่ำ (กก.) ที่จะ "ทิ้งรอย sliver" ครึ่งคันที่ filter ตัด ให้ B2 หาคู่เจอ (default 1000)
#                            แยกจาก gvw_ignored — กั้นมอไซค์/noise แต่เก็บครึ่งบรรทุกจริง (เช่น 1 เพลา 2,080kg)
#STRADDLE_PARTNER_FLOOR=1000

# (ลบ EdgeMirror/MIRROR_EDGE_ZONES — Type-2 mirror กู้ "ไหลทาง/คร่อมนุ่ม" อัตโนมัติทุกเลนแล้ว ไม่ต้องตั้งขอบ)
