# ==========================================
# การจับคู่รูปภาพรถ และ Performance Metrics
# ==========================================

# 1. การจับคู่รูปภาพ Snap กับข้อมูลรถ (หน่วย: ms)
# - SNAP_MATCH_DB_POLL_MS  = ความถี่ในการเช็คข้อมูลในฐานข้อมูลระหว่างรอรูป (ระบบมี event-driven เช็คใน memory ด้วย)
# - SNAP_MATCH_MAX_WAIT_MS = เวลารอรูปภาพสูงสุด (หากระบบจับคู่รูปไม่ทัน ให้ปรับค่านี้เพิ่มขึ้น)
SNAP_MATCH_DB_POLL_MS=1000
SNAP_MATCH_MAX_WAIT_MS=3000

# 2. Performance Metrics
# - METRICS_INTERVAL_MS = ช่วงเวลารอบการสรุป Log ประสิทธิภาพ (เช่น 300000 ms = 5 นาที)
# - METRICS_FORMAT      = รูปแบบแสดงผล: pretty (หลายบรรทัด อ่านง่าย) / compact (บรรทัดเดียว)
METRICS_INTERVAL_MS=300000
METRICS_FORMAT=pretty

# 3. กำหนดช่วงเวลาค้นหาจับคู่รูปภาพย้อนหลัง/ล่วงหน้า (หน่วย: ms)
# - ลบ # ด้านหน้าออก เพื่อเปิดใช้งาน (เป็นการ Override ค่าในฐานข้อมูลชั่วคราวโดยไม่ต้องแก้ DB)
# - SNAP_MATCH_BACK_MS = ช่วงเวลาจับคู่ย้อนหลัง (เทียบจาก snap_offset_*_ms ใน Metrics)
# - SNAP_MATCH_FWD_MS  = ช่วงเวลาจับคู่ล่วงหน้า (หากเจอรูปสลับคัน/ถ่ายท้ายรถ ให้ลองลดค่านี้ลง)
#SNAP_MATCH_BACK_MS=2000
#SNAP_MATCH_FWD_MS=8000

# 4. ขอบเขตเวลาตรวจสอบประวัติการยิงสัญญาณ Trigger ย้อนหลัง (หน่วย: ms)
# - TRIGGER_HISTORY_WINDOW_MS = ตรวจสอบประวัติปุ่มกดสตรีมมิ่งเพื่อเลี่ยงการใช้แผนสำรองถ่ายรูปสด
#TRIGGER_HISTORY_WINDOW_MS=3000